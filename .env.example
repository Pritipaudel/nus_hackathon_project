# Copy to `.env` in the project root. Docker Compose and local tooling read these.

# --- PostgreSQL (Compose + local backend when POSTGRES_HOST=localhost) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb
POSTGRES_PORT=55432
# POSTGRES_HOST=localhost   # omit in Docker backend (compose sets postgres)

# --- MinIO ---
MINIO_S3_PORT=7545
MINIO_CONSOLE_PORT=7546
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Local backend only (Compose overrides for containers):
# MINIO_ENDPOINT=localhost:7545
# Browser-facing URLs in API responses (match published S3 port):
# MINIO_PUBLIC_HOST=localhost:7545

# --- API ---
JWT_SECRET_KEY=change-me-in-production

# --- Docker Compose: frontend build args (optional) ---
# VITE_API_BASE_URL=http://localhost:8000/
# VITE_APP_NAME=उत्थान
# VITE_APP_ENV=production
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
